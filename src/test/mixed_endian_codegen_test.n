// nc

type void      { $size:0 };
type bool      { $size:1 };
type s2le      { $size:2 $signed $endian:little };
type s2be      { $size:2 $signed $endian:big };
type *         { $size:2 $unsigned $endian:little };

s2le assignmix(s2be a) {
   s2le b;
   b := a;
   return b;
}

s2le addmix(s2be a, s2le b) {
   return a + b;
}

bool cmpmix(s2be a, s2le b) {
   return a < b;
}
