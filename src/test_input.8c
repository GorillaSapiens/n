// Single-line comment

/* Block comment over
   multiple lines */

type uint8 { 1 #byte #packed };
//type * { 2 };
type float { 2 #byte #packed };

struct Point {
    int x;
    int y;
};

union Value {
    int i;
    float f;
};

Point origin := Point { x := 0; y := 0; };
Value v := Value { i := 42; };
Value { f := 3.14; };  // anonymous union literal
Point { x := -1; y := 2; };  // anonymous struct literal

main:
for (i := 0; i < 10; i := i + 1) {
    if (i == 5)
        break main;
    else
        continue;
}
;
do {
    // do-while loop with label
    continue main;
} while (i < 5);

switch (i) {
    case 1:
    case 2:
        i := 100;
        break;
    default:
        break;
}

label1:
while (i < 20) {
    i := i + 1;
    if (i % 2 == 0)
        continue label1;
    if (i > 15)
        break label1;
}

goto label1;

// Function call and assignment
foo := bar(1, 2, 3);

// Flags as standalone tokens (ignored in expr)
#debug_flag

// Unary operators
x := -1;
y := !x;
z := ~x;

// Binary and ternary expressions
a := x + y * z - (x >> 2);
b := x ? y : z;
