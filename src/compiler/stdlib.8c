type char  { 1 $signed };
type uchar { 1 $unsigned };


/////// pointer type

type *     { 2 $endian:little };

/////// void
// defining any operators for void would be meaningless.

type void  { 0 };

/////// bool
// really only two meaningful operations for bool

type bool  { 1 $unsigned };
bool operator==(bool,bool); // comparison ==
//bool operator!=(bool,bool); // comparison != skipped, see below

/////// int
// not all possible operators are required

type int   { 2 $signed $endian:little };
// bool operator{}(int);     // used by && || !, may be skipped if all 0x00 is false
// int  operator|(int,int);  // bitwise |, may be skipped if true bitwise or is ok
// int  operator^(int,int);  // bitwise ^, may be skipped if true bitwise xor is ok
// int  operator&(int,int);  // bitwise &, may be skipped if true bitwise and is ok
// bool operator==(int,int); // comparison ==, may be skipped if true bytewise comparison is ok
// bool operator!=(int,int); // comparison !=, may be skipped if == defined
bool operator<=(int,int); // comparison <=, may be skipped if > defined
// bool operator>=(int,int); // comparison >=, may be skipped if < defined
bool operator<(int,int);  // comparison <, may be skipped if >= defined
// bool operator>(int,int);  // comparison >, may be skipped if <= defined
// int  operator<<(int,int); // left shift, may be skipped if true bitwise left shift is ok
// int  operator>>(int,int); // right shift, may be skipped if true bitwise right shift is ok
int  operator+(int,int);  // addition
int  operator-(int,int);  // subtraction
int  operator*(int,int);  // multiplication
int  operator/(int,int);  // division
int  operator%(int,int);  // modulo
// int  operator~(int);      // bitwise negation, may be skipped if true bitwise negation is ok
int  operator-(int);      // unary negative
// int  operator+(int);      // unary positive, may be skipped if no-op
int  operator++(int);     // unary incremement
int  operator--(int);      // unary decrement


/////// uint
// see int above for reasons behind skipping some operators

type uint  { 2 $unsigned $endian:little };
bool operator<=(uint,uint);  // comparison <=, may be skipped if > defined
bool operator<(uint,uint);   // comparison <, may be skipped if >= defined
uint  operator+(uint,uint);  // addition
uint  operator-(uint,uint);  // subtraction
uint  operator*(uint,uint);  // multiplication
uint  operator/(uint,uint);  // division
uint  operator%(uint,uint);  // modulo
uint  operator-(uint);       // unary negative
uint  operator++(uint);      // unary incremement
uint  operator--(uint);      // unary decrement


/////// char
// see notes above
type char  { 1 $signed };
bool operator<=(char,char);  // comparison <=, may be skipped if > defined
bool operator<(char,char);   // comparison <, may be skipped if >= defined
char  operator+(char,char);  // addition
char  operator-(char,char);  // subtraction
char  operator*(char,char);  // multiplication
char  operator/(char,char);  // division
char  operator%(char,char);  // modulo
char  operator-(char);       // unary negative
char  operator++(char);      // unary incremement
char  operator--(char);      // unary decrement


/////// uchar
// see notes above
type char  { 1 $unsigned };
bool operator<=(uchar,uchar);  // comparison <=, may be skipped if > defined
bool operator<(uchar,uchar);   // comparison <, may be skipped if >= defined
uchar  operator+(uchar,uchar); // addition
uchar  operator-(uchar,uchar); // subtraction
uchar  operator*(uchar,uchar); // multiplication
uchar  operator/(uchar,uchar); // division
uchar  operator%(uchar,uchar); // modulo
uchar  operator-(uchar);       // unary negative
uchar  operator++(uchar);      // unary incremement
uchar  operator--(uchar);      // unary decrement
