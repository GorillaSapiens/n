// n65cc -I .
// expectsim: OK
// archive: e2e_archive_function_pointer__libthing.n
include "machine_6502.n"

int lib_value(void);

static char ok[4] := { 'O', 'K', '\n', 0 };
static char bad[5] := { 'B', 'A', 'D', '\n', 0 };

void print_ok(void) {
   asm lda #0;
   asm ldx #<ok;
   asm ldy #>ok;
   asm jsr $ffff;
}

void print_bad(void) {
   asm lda #0;
   asm ldx #<bad;
   asm ldy #>bad;
   asm jsr $ffff;
}

int inc(int x) {
   return x + 1;
}

int (*fp)(int) := inc;

void main(void) {
   if (lib_value() == 9) {
      if (fp(4) == 5) {
         print_ok();
      }
      else {
         print_bad();
      }
   }
   else {
      print_bad();
   }
   while (1) {
   }
}
