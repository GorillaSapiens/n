// n65cc -I .
// expectasmordered: lda #$40
// expectasmordered: eor #$ff
// expectasmordered: lda #$01
// expectasmordered: sta arg0
// expectasmordered: jsr _bit_andN

include "machine_6502.n"

type BYTE { $size:1 $integer:unsigned };

alias FA__WIP 0x40

BYTE clear(BYTE flag) {
   flag &= ~FA__WIP;
   return flag;
}
