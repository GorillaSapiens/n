// n65cc -I .
// expectasmordered: jsr helper__char_p1_a0__u1x_p0_a0
// expectasmordered: jsr helper__char_p1_a0__u2x_p0_a0
// expectasmordered: jsr helper__char_p1_a0__u1x_p0_a0
// expectasmordered: jsr helper__char_p1_a0__u2x_p0_a0

include "machine_6502.n"

type u1x { $size:1 $unsigned $endian:little };
type u2x { $size:2 $unsigned $endian:little };

int helper(char *dst, u1x value) {
   dst[0] := 'a' + value;
   return 1;
}

int helper(char *dst, u2x value) {
   dst[0] := 'A' + (value & 15`u2x);
   return 1;
}

void main(void) {
   char buf[8];
   char *p := buf;
   u1x b := 1`u1x;
   u2x w := 2`u2x;

   helper(buf, b);
   helper(buf + 1, w);
   helper(p + 2, b);
   helper("xy" + 1, w);
}
