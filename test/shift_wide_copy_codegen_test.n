include "machine_6502.n"

type u6 { $size:6 $unsigned $endian:little };
type s6 { $size:6 $signed $endian:little };

u6 expr_u(u6 a, int b) {
   return a >> b;
}

u6 expr_ul(u6 a, int b) {
   return a << b;
}

void assign_s(ref s6 a, int b) {
   a >>= b;
}
