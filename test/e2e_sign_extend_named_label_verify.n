// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type s2 { $size:2 $integer:signed $endian:little };
type u3 { $size:3 $integer:unsigned $endian:little };

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   s2 a := 1;
   u3 g := 0;

   a := 0 - a;
   g := a;
   if (g != 0xffffff`u3) {
      asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff;
   }

   a := 0x1234;
   g := a;
   if (g != 0x001234`u3) {
      asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff;
   }

   pass();
}
