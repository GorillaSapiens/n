// n65cc -I .
// expectexit: 0
// archive: generated_float_archive_gf32_operator_add.n
include "machine_6502.n"
include "generated_float_archive_gf32_decls.n"

union gf32_bits {
   gf32 f;
   char b[4];
};

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

ref char gfailcode@[none/0x02f0];

void fail(int code) {
   gfailcode := code;
   asm lda #$ff;
   asm ldx $02f0;
   asm ldy #0;
   asm jsr $ffff;
}

void expect4(gf32_bits got, gf32_bits want, int code) {
   if (got.b[0] != want.b[0]) { fail(code + 0); }
   if (got.b[1] != want.b[1]) { fail(code + 1); }
   if (got.b[2] != want.b[2]) { fail(code + 2); }
   if (got.b[3] != want.b[3]) { fail(code + 3); }
}

void main(void) {
   gf32_bits one;
   gf32_bits halfv;
   gf32_bits onep5;
   gf32_bits mone;
   gf32_bits mtwo;
   gf32_bits mthree;
   gf32_bits got;

   one.f := 1.0;
   halfv.f := 0.5;
   onep5.f := 1.5;
   mone.f := -1.0;
   mtwo.f := -2.0;
   mthree.f := -3.0;

   got.f := one.f + halfv.f;
   expect4(got, onep5, 1);

   got.f := mone.f + mtwo.f;
   expect4(got, mthree, 5);

   pass();
}
