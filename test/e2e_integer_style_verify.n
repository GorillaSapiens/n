// n65cc -I test -o test.out
// xfail: sometimes x64 somehow uses $80 as the exit code

type void { $size:0 };
type bool { $size:1 $integer:unsigned };
type *    { $size:2 $integer:unsigned $endian:little };
type s1   { $size:1 $integer:signed };
type s2   { $size:2 $integer:signed $endian:little };
type u2   { $size:2 $integer:unsigned $endian:little };

s2 widen(s1 x) {
   s2 out := x;
   return out;
}

bool ge(u2 a, u2 b) {
   return a >= b;
}

s2 main(void) {
   if (widen(0xff`s1) != 0xffff`s2) {
      return 1;
   }
   if (!ge(1`u2, 1`u2)) {
      return 2;
   }
   return 0;
}
