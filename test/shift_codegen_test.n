// n65cc
// expectasm: jsr _asrN
// expectasm: lda #$02
// expectasm: sta arg0
// expectasm: jsr _lsrN

type void      { $size:0 };
type bool      { $size:1 };
type s1        { $size:1 $signed $endian:little };
type u2        { $size:2 $unsigned $endian:little };
type u4        { $size:4 $unsigned $endian:little };
type s2        { $size:2 $signed $endian:little };
type *         { $size:2 $unsigned $endian:little };

s1 shr_expr(s1 a, u4 b) {
   return a >> b;
}

u2 lshr_assign(u2 a, u4 b) {
   a >>= b;
   return a;
}
