// nc -I .
// expectasm: #<((0x00) + 0)
// expectasm: #<((0x80) + 0)
// expectasm: #<((0x100) + 0)
// expectasm: #<((0x180) + 0)

include "machine_6502.n"

type u8  { $size:1 $unsigned };
type u16 { $size:2 $unsigned $endian:little };

ref u8 ro@[0x00/none];
ref u8 wo@[none/0x80];
ref u16 banked@[0x100/0x180];

u8 sink;

int main(void) {
   sink := ro;
   banked := 0x1234;
   wo := sink;
   sink := banked;
   return 0;
}
