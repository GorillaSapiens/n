// n65cc -I .

type void  { $size:0 };
type bool  { $size:1 $integer:unsigned };
type *     { $size:2 $integer:unsigned $endian:little };
type char  { $size:1 $integer:signed };
type BYTE  { $size:1 $integer:unsigned };
type int   { $size:2 $integer:signed $endian:little };

static int mem_cmp(const void* dst, const void* src, int cnt) {
   return cnt;
}

int main(void) {
   BYTE a[11], b[11];
   return mem_cmp(a, b, 11);
}
