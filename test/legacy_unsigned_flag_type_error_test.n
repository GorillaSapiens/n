// n65cc
// expectfail
// expecterr: must use '$integer:signed' or '$integer:unsigned' instead of '$unsigned'

type void { $size:0 };
type bool { $size:1 $integer:unsigned };
type *    { $size:2 $integer:unsigned $endian:little };
type bad  { $size:2 $unsigned $endian:little };

bad main(void) {
   return 0;
}
