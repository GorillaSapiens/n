// n65cc -I .
// expectexit: 0
include "machine_6502.n"

type gf64 { $size:8 $endian:little $float:ieee754 };
include "generated_gf64_mul_ops.n"

union gf64_bits {
   gf64 f;
   char b[8];
};

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

ref char gfailcode@[none/0x02f0];

void fail(int code) {
   gfailcode := code;
   asm lda #$ff;
   asm ldx $02f0;
   asm ldy #0;
   asm jsr $ffff;
}

void expect8(gf64_bits got, gf64_bits want, int code) {
   if (got.b[0] != want.b[0]) { fail(code + 0); }
   if (got.b[1] != want.b[1]) { fail(code + 1); }
   if (got.b[2] != want.b[2]) { fail(code + 2); }
   if (got.b[3] != want.b[3]) { fail(code + 3); }
   if (got.b[4] != want.b[4]) { fail(code + 4); }
   if (got.b[5] != want.b[5]) { fail(code + 5); }
   if (got.b[6] != want.b[6]) { fail(code + 6); }
   if (got.b[7] != want.b[7]) { fail(code + 7); }
}

void main(void) {
   gf64_bits one;
   gf64_bits halfv;
   gf64_bits onep5;
   gf64_bits two;
   gf64_bits threeq;
   gf64_bits zero;
   gf64_bits mhalf;
   gf64_bits mone;
   gf64_bits special;
   gf64_bits pinf;
   gf64_bits ninf;
   gf64_bits nanv;
   gf64_bits qnan;

   one.f := 1.0;
   halfv.f := 0.5;
   onep5.f := 1.5;
   two.f := 2.0;
   threeq.f := 0.75;
   zero.f := 0.0;
   mhalf.f := -0.5;
   mone.f := -1.0;

   pinf.b[0] := 0x00; pinf.b[1] := 0x00; pinf.b[2] := 0x00; pinf.b[3] := 0x00;
   pinf.b[4] := 0x00; pinf.b[5] := 0x00; pinf.b[6] := 0xf0; pinf.b[7] := 0x7f;
   ninf.b[0] := 0x00; ninf.b[1] := 0x00; ninf.b[2] := 0x00; ninf.b[3] := 0x00;
   ninf.b[4] := 0x00; ninf.b[5] := 0x00; ninf.b[6] := 0xf0; ninf.b[7] := 0xff;
   nanv.b[0] := 0x01; nanv.b[1] := 0x00; nanv.b[2] := 0x00; nanv.b[3] := 0x00;
   nanv.b[4] := 0x00; nanv.b[5] := 0x00; nanv.b[6] := 0xf0; nanv.b[7] := 0x7f;
   qnan.b[0] := 0x00; qnan.b[1] := 0x00; qnan.b[2] := 0x00; qnan.b[3] := 0x00;
   qnan.b[4] := 0x00; qnan.b[5] := 0x00; qnan.b[6] := 0xf8; qnan.b[7] := 0x7f;

   special.f := onep5.f * halfv.f;
   expect8(special, threeq, 1);

   special.f := mhalf.f * two.f;
   expect8(special, mone, 17);

   special.f := pinf.f * mhalf.f;
   expect8(special, ninf, 25);

   special.f := pinf.f * zero.f;
   expect8(special, qnan, 33);

   special.f := nanv.f * one.f;
   expect8(special, nanv, 41);

   pass();
}
