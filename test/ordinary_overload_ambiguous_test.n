// n65cc
// expectfail
// expecterr: ambiguous call to overloaded function 'pick'

type void { $size:0 };
type bool { $size:1 $integer:unsigned };
type *    { $size:2 $integer:unsigned $endian:little };
type s4   { $size:4 $integer:signed $endian:little };
type s5   { $size:5 $integer:signed $endian:little };

s4 pick(s4 a, s5 b) {
   return a;
}

s5 pick(s5 a, s4 b) {
   return b;
}

s4 use_ambiguous(s4 x, s4 y) {
   return pick(x, y);
}
