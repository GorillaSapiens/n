// n65cc -I .
// expectexit: 0
// archive: generated_float_archive_gf32_operator_div.n
include "machine_6502.n"
include "generated_float_archive_gf32_decls.n"

union gf32_bits {
   gf32 f;
   char b[4];
};

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

ref char gfailcode@[none/0x02f0];

void fail(int code) {
   gfailcode := code;
   asm lda #$ff;
   asm ldx $02f0;
   asm ldy #0;
   asm jsr $ffff;
}

void expect4(gf32_bits got, gf32_bits want, int code) {
   if (got.b[0] != want.b[0]) { fail(code + 0); }
   if (got.b[1] != want.b[1]) { fail(code + 1); }
   if (got.b[2] != want.b[2]) { fail(code + 2); }
   if (got.b[3] != want.b[3]) { fail(code + 3); }
}

void main(void) {
   gf32_bits three;
   gf32_bits two;
   gf32_bits onep5;
   gf32_bits mthree;
   gf32_bits mtwo;
   gf32_bits one;
   gf32_bits mone;
   gf32_bits zero;
   gf32_bits pinf;
   gf32_bits ninf;
   gf32_bits got;

   three.f := 3.0;
   two.f := 2.0;
   onep5.f := 1.5;
   mthree.f := -3.0;
   mtwo.f := -2.0;
   one.f := 1.0;
   mone.f := -1.0;
   zero.f := 0.0;
   pinf.b[0] := 0x00; pinf.b[1] := 0x00; pinf.b[2] := 0x80; pinf.b[3] := 0x7f;
   ninf.b[0] := 0x00; ninf.b[1] := 0x00; ninf.b[2] := 0x80; ninf.b[3] := 0xff;

   got.f := three.f / two.f;
   expect4(got, onep5, 1);

   got.f := mthree.f / mtwo.f;
   expect4(got, onep5, 5);

   got.f := one.f / zero.f;
   expect4(got, pinf, 9);

   got.f := mone.f / zero.f;
   expect4(got, ninf, 13);

   pass();
}
