// expectasmordered: case_choice
// expectasmordered: ?:
// expectasmordered: ==
// expectasmordered: *
// expectasmordered: +
// expectasmordered: integer_literal 1
// expectasmordered: integer_literal 2
// expectasmordered: integer_literal 3
// expectasmordered: integer_literal 9
// expectasmordered: integer_literal 7
// expectasmordered: integer_literal 8
// expectasmordered: case_choice
// expectasmordered: +
// expectasmordered: ~
// expectasmordered: integer_literal 1
// expectasmordered: integer_literal 5
// expectasmordered: <<
// expectasmordered: integer_literal 1
// expectasmordered: integer_literal 3

include "machine_6502.n"

int main(void) {
   int x := 0;
   switch (x) {
      case ((1 + 2) * 3 == 9) ? 7 : 8:
         return 1;
      case ~1 + 5 .. 1 << 3:
         return 2;
      default:
         return 3;
   }
}
