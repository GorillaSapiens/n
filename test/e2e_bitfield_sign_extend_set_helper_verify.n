// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type s4x { $size:4 $signed $endian:little };

struct Bits {
   s4x value:20;
};

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   Bits b;
   s4x out := 0;

   b.value := 0xfffff`s4x;
   out := b.value;
   if (out != 0xffffffff`s4x) {
      asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff;
   }

   b.value := 0x54321;
   out := b.value;
   if (out != 0x00054321`s4x) {
      asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff;
   }

   pass();
}
