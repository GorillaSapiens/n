// n65cc
// expectfail
// expecterr: mixed signed/unsigned ordinary integer operator '<' requires an explicit cast

type void { $size:0 };
type bool { $size:1 };
type *    { $size:2 $unsigned $endian:little };
type s2   { $size:2 $signed $endian:little };
type u4   { $size:4 $unsigned $endian:little };

bool bad(s2 a, u4 b) {
   return a < b;
}
