// n65cc -I .
// expectasm: .zpexport a?
// expectasm: .export b
// expectasm: a?:
// expectasm: .byte $05, $00
// expectasm: b:
mem banana   { $start:0x0000 $size:0x0100 $rw };
mem zeropage { $start:0x0100 $size:0x0100 $rw };

 type void { $size:0 };
 type bool { $size:1 $integer:unsigned };
 type char { $size:1 $integer:signed};
 type * { $size:2 $integer:unsigned $endian:little };
 type int { $size:2 $integer:signed $endian:little };

banana int a := 5;
zeropage int b := 6;

int main(void) {
   return a;
}
