// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type u2be { $size:2 $unsigned $endian:big };
type u2le { $size:2 $unsigned $endian:little };

void main(void) {
   u2le a[4];
   u2le idx;
   u2be raw := 0x0002`u2be;
   u2le *p;

   a[0] := 11`u2le;
   a[1] := 22`u2le;
   a[2] := 33`u2le;
   a[3] := 44`u2le;

   idx := (u2le)raw;
   if (idx != 2`u2le) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }

   p := &a[0];
   p += idx;
   if (p[0] != 33`u2le) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }

   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
