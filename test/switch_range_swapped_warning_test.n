// n65cc
// expecterr: case range bounds were reversed; compiling as the inclusive range in ascending order

type void      { $size:0 };
type bool      { $size:1 };
type char      { $size:1 $signed };
type uchar     { $size:1 $unsigned };
type *         { $size:2 $unsigned $endian:little };
type short     { $size:2 $signed $endian:little };
type ushort    { $size:2 $unsigned $endian:little };
type int       { $size:4 $signed $endian:little };
type uint      { $size:4 $unsigned $endian:little };

int main(void) {
   int x := 3;
   switch (x) {
      case 5 to 2:
         return 1;
      default:
         return 0;
   }
}
