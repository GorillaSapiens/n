// n65cc -I .
// expectasm: .proc scan
// forbidasm: builtin variadic support requires type 'char'
type bool { $size:1 $integer:unsigned };
type void { $size:0 };
type * { $size:2 $integer:unsigned $endian:little };
type int { $size:2 $integer:signed $endian:little };
int scan(int tag, ...) {
   return tag;
}
