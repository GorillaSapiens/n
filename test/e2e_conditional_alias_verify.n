// n65cc -I .
// expectexit: 0

include "machine_6502.n"

alias WHICH 2

#if defined(WHICH) && (WHICH > 1) && (WHICH <= 2)
alias VALUE 9
#else
alias VALUE 4
#endif

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   int x := VALUE;

   if (x != 9) {
      asm lda #$ff;
      asm ldx #1;
      asm ldy #0;
      asm jsr $ffff;
   }

   pass();
}
