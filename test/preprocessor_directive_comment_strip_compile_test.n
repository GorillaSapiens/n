// n65cc -I .

include "machine_6502.n"

alias FOO 1

#if FOO == 1   /* object-like alias in conditional */
// this line should compile because the directive comment is ignored
#else   // also ignored
this is broken
#endif   /* comment after endif */

#ifdef FOO   // comment after ifdef
#ifndef BAR  /* comment after ifndef */
void main(void) {
   int x;
   x := 1;
}
#else // ignored
this is broken too
#endif /* ignored */
#else /* ignored */
this is broken three
#endif // ignored
