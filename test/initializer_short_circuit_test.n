// nc
// expectasm: _and_short:
// expectasm: 	.byte $00
// expectasm: _or_short:
// expectasm: 	.byte $01
// expectasm: _ternary:
// expectasm: 	.byte $07, $00, $00

type bool     { $size:1 };
type void     { $size:0 };
type *        { $size:2 $unsigned $endian:little };
type uint24_t { $size:3 $unsigned $endian:little };

bool and_short := 0 && (1 / 0);
bool or_short := 1 || (1 / 0);
uint24_t ternary := (0 ? (1 / 0) : 7);

void main(void) {
}
