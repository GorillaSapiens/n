// n65cc
// expectfail
// expecterr: mixed-endian ordinary integer operator '<<' is not supported; use an explicit cast or matching endianness

type void { $size:0 };
type bool { $size:1 $integer:unsigned };
type *    { $size:2 $integer:unsigned $endian:little };
type u2le { $size:2 $integer:unsigned $endian:little };
type u2be { $size:2 $integer:unsigned $endian:big };

u2be bad(u2be a, u2le b) {
   return a << b;
}
