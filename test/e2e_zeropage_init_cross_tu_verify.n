// n65cc -I .
// expectsim: OK
// object: e2e_zeropage_init_cross_tu_verify__def.n
include "machine_6502.n"

static char ok[4] := { 'O', 'K', '\n', 0 };
static char bad[5] := { 'B', 'A', 'D', '\n', 0 };

extern zeropage int shared;

void print_ok(void) {
   asm lda #0;
   asm ldx #<ok;
   asm ldy #>ok;
   asm jsr $ffff;
}

void print_bad(void) {
   asm lda #0;
   asm ldx #<bad;
   asm ldy #>bad;
   asm jsr $ffff;
}

void main(void) {
   if (shared == 7) {
      print_ok();
   }
   else {
      print_bad();
   }
   while (1) {
   }
}
