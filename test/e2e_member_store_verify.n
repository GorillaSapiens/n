// n65cc -I .
// expectexit: 0
include "machine_6502.n"

union U {
   int i;
   char b[2];
};

struct S {
   char a[4];
   U u;
};

U gu;
S gs;
int idx;

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   idx := 0;
   while (idx < sizeof(gu.b)) {
      gu.b[idx] := idx + 1;
      idx++;
   }

   if (gu.b[0] != 1)              { asm lda #$ff; asm ldx #1;  asm ldy #0; asm jsr $ffff; }
   if (gu.b[1] != 2)              { asm lda #$ff; asm ldx #2;  asm ldy #0; asm jsr $ffff; }
   if (gu.i != 0x0201)            { asm lda #$ff; asm ldx #3;  asm ldy #0; asm jsr $ffff; }

   gs.a[0] := 0x10;
   gs.a[1] := 0x11;
   gs.a[2] := 0x12;
   gs.a[3] := 0x13;

   if (gs.a[0] != 0x10)           { asm lda #$ff; asm ldx #4;  asm ldy #0; asm jsr $ffff; }
   if (gs.a[3] != 0x13)           { asm lda #$ff; asm ldx #5;  asm ldy #0; asm jsr $ffff; }
   if (sizeof(gs.a) != 4)         { asm lda #$ff; asm ldx #6;  asm ldy #0; asm jsr $ffff; }

   idx := 0;
   while (idx < sizeof(gs.u.b)) {
      gs.u.b[idx] := idx + 3;
      idx++;
   }

   if (gs.u.b[0] != 3)            { asm lda #$ff; asm ldx #7;  asm ldy #0; asm jsr $ffff; }
   if (gs.u.b[1] != 4)            { asm lda #$ff; asm ldx #8;  asm ldy #0; asm jsr $ffff; }
   if (gs.u.i != 0x0403)          { asm lda #$ff; asm ldx #9;  asm ldy #0; asm jsr $ffff; }
   if (gs.a[1] != 0x11)           { asm lda #$ff; asm ldx #10; asm ldy #0; asm jsr $ffff; }

   pass();
}
