// n65cc -I .
// expectexit: 0
include "machine_6502.n"

type gf3le { $size:3 $endian:little $float:simple };
include "generated_gf3le_mul_ops.n"

union gf3le_bits {
   gf3le f;
   char b[3];
};

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

ref char gfailcode@[none/0x02f0];

void fail(int code) {
   gfailcode := code;
   asm lda #$ff;
   asm ldx $02f0;
   asm ldy #0;
   asm jsr $ffff;
}

void expect3(gf3le_bits got, gf3le_bits want, int code) {
   if (got.b[0] != want.b[0]) { fail(code + 0); }
   if (got.b[1] != want.b[1]) { fail(code + 1); }
   if (got.b[2] != want.b[2]) { fail(code + 2); }
}

void main(void) {
   gf3le_bits one;
   gf3le_bits halfv;
   gf3le_bits onep5;
   gf3le_bits two;
   gf3le_bits threeq;
   gf3le_bits mhalf;
   gf3le_bits mone;
   gf3le_bits got;

   one.f := 1.0;
   halfv.f := 0.5;
   onep5.f := 1.5;
   two.f := 2.0;
   threeq.f := 0.75;
   mhalf.f := -0.5;
   mone.f := -1.0;

   got.f := onep5.f * halfv.f;
   expect3(got, threeq, 1);
   got.f := mhalf.f * two.f;
   expect3(got, mone, 4);

   pass();
}
