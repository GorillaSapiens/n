// n65cc

type void      { $size:0 };
type bool     { $size:1 $integer:unsigned };
type char      { $size:1    $integer:signed };
type uchar     { $size:1  $integer:unsigned };
type *         { $size:2  $integer:unsigned $endian:little };
type short     { $size:2    $integer:signed $endian:little };
type ushort    { $size:2  $integer:unsigned $endian:little };
type int       { $size:4    $integer:signed $endian:little };
type uint      { $size:4  $integer:unsigned $endian:little };
type long      { $size:8    $integer:signed $endian:little };
type ulong     { $size:8  $integer:unsigned $endian:little };
type longlong  { $size:16   $integer:signed $endian:little };
type ulonglong { $size:16 $integer:unsigned $endian:little };
type float     { $size:4            $endian:little $float:ieee754 };  // IEEE 754 binary32
type double    { $size:8            $endian:little $float:ieee754 }; // IEEE 754 binary64

int main(int argc, char **argv) {
   int x := 1;
   int y := 2;
   x += y;
   x++;
   x -= 1;
   --x;
   return x;
}
