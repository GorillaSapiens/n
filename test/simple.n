// n65cc

type void      { $size:0 };
type bool     { $size:1 };
type char      { $size:1    $signed };
type uchar     { $size:1  $unsigned };
type *         { $size:2  $unsigned $endian:little };
type short     { $size:2    $signed $endian:little };
type ushort    { $size:2  $unsigned $endian:little };
type int       { $size:4    $signed $endian:little };
type uint      { $size:4  $unsigned $endian:little };
type long      { $size:8    $signed $endian:little };
type ulong     { $size:8  $unsigned $endian:little };
type longlong  { $size:16   $signed $endian:little };
type ulonglong { $size:16 $unsigned $endian:little };
type float     { $size:4            $endian:little $float };
type double    { $size:8            $endian:little $float };

static char **argv;

int main(int argc, char **argv) {
}
