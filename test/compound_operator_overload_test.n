// n65cc
// expectasm: jsr operatorx2B__int_p0_a0__int_p0_a0
// expectasm: jsr operatorx3Cx3C__int_p0_a0__int_p0_a0
// expectasm: jsr operatorx26__int_p0_a0__int_p0_a0

type void { $size:0 };
type bool { $size:1 $integer:unsigned };
type *    { $size:2 $integer:unsigned $endian:little };
type int  { $size:2 $integer:signed $endian:little };

int operator+(int a, int b) {
   return a;
}

int operator<<(int a, int b) {
   return a;
}

int operator&(int a, int b) {
   return a;
}

int main(void) {
   int x;
   int y;
   x += y;
   x <<= y;
   x &= y;
   return x;
}
