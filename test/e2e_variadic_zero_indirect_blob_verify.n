// n65cc -I .
// expectexit: 0

include "machine_6502.n"

int sniff(int tag, ...) {
   char *p := __va_args;

   if (tag != 0x1020) { return 1; }
   if (__va_arg_bytes != 0) { return 2; }
   if (p != __va_args) { return 3; }
   return 0;
}

int (*fp)(int tag, ...) := sniff;

void main(void) {
   if (fp(0x1020) != 0) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
