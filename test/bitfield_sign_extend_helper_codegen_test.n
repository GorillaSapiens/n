// n65cc -I .
// expectasm: .import _zeroN
// expectasm: .import _setN
// expectasmordered: jsr _zeroN
// expectasmordered: ora #$f0
// expectasmordered: lda #$01
// expectasmordered: sta arg0
// expectasmordered: lda #$ff
// expectasmordered: sta arg1
// expectasmordered: jsr _setN

include "machine_6502.n"

type s4x { $size:4 $integer:signed $endian:little };

struct Bits {
   s4x value:20;
};

s4x widen(Bits b) {
   s4x out;
   out := b.value;
   return out;
}
