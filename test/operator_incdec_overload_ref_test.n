// n65cc
// expectasm: jsr operatorx2Bx2B__int_r1_p0_a0
// expectasm: jsr operatorx2Dx2D__int_r1_p0_a0

type void { $size:0 };
type bool { $size:1 $integer:unsigned };
type *    { $size:2 $integer:unsigned $endian:little };
type int  { $size:2 $integer:signed $endian:little };

int operator++(ref int a) {
   a := a + 1;
   return a;
}

int operator--(ref int a) {
   a := a - 1;
   return a;
}

int main(void) {
   int x;
   int a := x++;
   int b := ++x;
   int c := x--;
   int d := --x;
   x++;
   --x;
   return a + b + c + d + x;
}
