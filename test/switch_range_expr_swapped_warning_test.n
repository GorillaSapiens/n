// n65cc -I .
// expecterr: case range bounds were reversed; compiling as the inclusive range in ascending order
// expectasmordered: lda #$02
// expectasmordered: jsr _leNs
// expectasmordered: lda #$05
// expectasmordered: jsr _leNs
// expectasmordered: bne @case_

include "machine_6502.n"

int main(void) {
   int x := 3;
   switch (x) {
      case 5 - 0 to 1 + 1:
         return 1;
      default:
         return 0;
   }
}
