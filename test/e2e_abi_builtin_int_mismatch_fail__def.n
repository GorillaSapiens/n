mem zeropage { $start:0x0000 $size:0x0100 $rw };
mem cpustack { $start:0x0100 $size:0x0100 $rw };
mem ram      { $start:0x0200 $size:0x7e00 $rw $priority:2 };
mem rom      { $start:0x8000 $size:0x8000 $ro $priority:1 };

type void     { $size:0 };
type char     { $size:1 $integer:signed };
type bool     { $size:1 $integer:unsigned };
type *        { $size:2 $integer:unsigned $endian:little };
type int      { $size:4 $integer:signed $endian:little };
type long     { $size:4 $integer:signed $endian:little };
type longlong { $size:8 $integer:signed $endian:little };

int helper(int x) {
   return x;
}
