// archivegroup: gf32_exactops_archive generated_float_archive_gf32_add_impl.n generated_float_archive_gf32_cmp_impl.n generated_float_archive_gf32_core.n
include "machine_6502.n"
include "generated_float_archive_gf32_decls.n"

union gf32_bits {
   gf32 f;
   char b[4];
};

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

ref char gfailcode@[none/0x02f0];

void fail(int code) {
   gfailcode := code;
   asm lda #$ff;
   asm ldx $02f0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   gf32_bits zero;
   gf32_bits one;
   gf32_bits two;
   gf32_bits negone;
   gf32 x;

   zero.f := 0.0;
   one.f := 1.0;
   two.f := 2.0;
   negone.f := -one.f;

   if (zero.f)             { fail(1); }
   if (!one.f)             { fail(2); }
   if (!(+one.f == one.f)) { fail(3); }
   if (!(negone.f < zero.f)) { fail(4); }

   x := one.f - two.f;
   if (!(x == negone.f))   { fail(5); }
   if (!(two.f > one.f))   { fail(6); }
   if (!(one.f <= one.f))  { fail(7); }
   if (!(one.f >= one.f))  { fail(8); }
   if (one.f != one.f)     { fail(9); }
   if (!(one.f != two.f))  { fail(10); }

   pass();
}
