// n65cc
// expectfail
// expecterr: cannot combine '$float:*' with '$integer:signed'

type void { $size:0 };
type bool { $size:1 $integer:unsigned };
type *    { $size:2 $integer:unsigned $endian:little };
type bad  { $size:4 $integer:signed $float:ieee754 $endian:little };

bad main(void) {
   return 0.0;
}
