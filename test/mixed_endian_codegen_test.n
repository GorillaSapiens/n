// n65cc

type void      { $size:0 };
type bool      { $size:1 $integer:unsigned };
type s2le      { $size:2 $integer:signed $endian:little };
type s2be      { $size:2 $integer:signed $endian:big };
type *         { $size:2 $integer:unsigned $endian:little };

s2le assignmix(s2be a) {
   s2le b;
   b := a;
   return b;
}

s2le castmix(s2be a) {
   return (s2le)a;
}
