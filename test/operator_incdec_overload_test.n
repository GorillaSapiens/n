// n65cc
// expectasm: jsr operatorx2Bx2B__int_p0_a0
// expectasm: jsr operatorx2Dx2D__int_p0_a0

type void { $size:0 };
type bool { $size:1 $integer:unsigned };
type *    { $size:2 $integer:unsigned $endian:little };
type int  { $size:2 $integer:signed $endian:little };

int operator++(int a) {
   int r;
   return r;
}

int operator--(int a) {
   int r;
   return r;
}

int main(void) {
   int x;
   int a := x++;
   int b := ++x;
   int c := x--;
   int d := --x;
   return a + b + c + d;
}
