// n65cc -I .
// expectexit: 0

include "machine_6502.n"

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   int cond;
   int iftrue := 11;
   int iffalse := 22;
   int out;

   cond := 0;
   out := cond ? iftrue : iffalse;
   if (out != 22) {
      asm lda #$ff;
      asm ldx #1;
      asm ldy #0;
      asm jsr $ffff;
   }

   cond := 1;
   out := cond ? iftrue : iffalse;
   if (out != 11) {
      asm lda #$ff;
      asm ldx #2;
      asm ldy #0;
      asm jsr $ffff;
   }

   pass();
}
