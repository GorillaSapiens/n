// n65cc
// expectasm: _bump$x:
// expectasm: 	.res 2
// expectasm: sta _bump$x,y

type void { $size:0 };
type bool { $size:1 };
type *    { $size:2 $unsigned $endian:little };
type u1   { $size:1 $unsigned $endian:little };
type int  { $size:2 $signed $endian:little };

int bump(static ref u1 x, int y) {
   x += y;
   return x;
}

int main(void) {
   u1 a := 7;
   return bump(a, 2);
}
