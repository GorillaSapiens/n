// n65cc
// expectasm: jsr _operatorx2B__s4_p0_a0__s4_p0_a0
// expectasm: jsr _operatorx2B__s5_p0_a0__s5_p0_a0
// expectasm: jsr _operatorx2D__s4_p0_a0

type void { $size:0 };
type bool { $size:1 };
type *    { $size:2 $unsigned $endian:little };
type s2   { $size:2 $signed $endian:little };
type s4   { $size:4 $signed $endian:little };
type u4   { $size:4 $unsigned $endian:little };
type s5   { $size:5 $signed $endian:little };

s4 operator+(s4 a, s4 b) {
   return a;
}

s5 operator+(s5 a, s5 b) {
   return a;
}

s4 operator-(s4 a) {
   return a;
}

s4 addmix(s2 a, s4 b) {
   return a + b;
}

s5 mixsign(s2 a, u4 b) {
   return a + b;
}

s4 negmix(s2 a) {
   return -a;
}
