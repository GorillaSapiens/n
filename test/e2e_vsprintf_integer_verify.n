// n65cc -I . -I ../libraries/nlib
// expectexit: 0

include "machine_6502.n"
include "sprintf.n"


int text_len(char *s) {
   int n := 0;
   while (s[n] != 0) {
      n := n + 1;
   }
   return n;
}

int expect_text(char *got, char *want, int code) {
   int i := 0;
   while (got[i] == want[i] && want[i] != 0) {
      i := i + 1;
   }
   if (got[i] != want[i]) {
      return code;
   }
   return 0;
}

int fill(char *dst, char *fmt, ...) {
   va_list ap;
   int count;

   va_start(ap);
   count := vsprintf(dst, fmt, ap);
   va_end(ap);
   return count;
}

void main(void) {
   char buf[96];
   int count;
   fmt_s1 s1 := 0`fmt_s1 - 8`fmt_s1;
   fmt_s2 s2 := 3210`fmt_s2;
   fmt_s4 s4 := 90000`fmt_s4;
   fmt_s8 s8 := 6000000000`fmt_s8;
   fmt_u1 u1 := 0x5c`fmt_u1;
   fmt_u2 u2 := 0x1234`fmt_u2;
   fmt_u4 u4 := 0xc001d00d`fmt_u4;
   fmt_u8 u8 := 0xfedcba9876543210`fmt_u8;
   char *want := "-8 3210 90000 6000000000 5c 1234 c001d00d fedcba9876543210";

   count := fill(buf, "%hhi %i %li %lli %hhx %x %lx %llx", s1, s2, s4, s8, u1, u2, u4, u8);
   if (expect_text(buf, want, 1) != 0) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   if (count != text_len(want)) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }

   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
