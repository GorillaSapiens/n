// n65cc
// expectasm: jsr pick__s2_p0_a0
// expectasm: jsr pick__s4_p0_a0

type void { $size:0 };
type bool { $size:1 };
type *    { $size:2 $unsigned $endian:little };
type s2   { $size:2 $signed $endian:little };
type s4   { $size:4 $signed $endian:little };

s2 pick(s2 x) {
   return x;
}

s4 pick(s4 x) {
   return x;
}

s2 use_small(s2 x) {
   return pick(x);
}

s4 use_big(s4 x) {
   return pick(x);
}
