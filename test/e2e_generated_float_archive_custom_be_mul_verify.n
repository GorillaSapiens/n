// n65cc -I .
// expectexit: 0
// archivegroup: gf3be_mul_archive generated_float_archive_gf3be_operator_mul.n generated_float_archive_gf3be_mul_impl.n generated_float_archive_gf3be_core.n
include "machine_6502.n"
include "generated_float_archive_gf3be_decls.n"

union gf3be_bits {
   gf3be f;
   char b[3];
};

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

ref char gfailcode@[none/0x02f0];

void fail(int code) {
   gfailcode := code;
   asm lda #$ff;
   asm ldx $02f0;
   asm ldy #0;
   asm jsr $ffff;
}

void expect3(gf3be_bits got, gf3be_bits want, int code) {
   if (got.b[0] != want.b[0]) { fail(code + 0); }
   if (got.b[1] != want.b[1]) { fail(code + 1); }
   if (got.b[2] != want.b[2]) { fail(code + 2); }
}

void main(void) {
   gf3be_bits halfv;
   gf3be_bits onep5;
   gf3be_bits two;
   gf3be_bits threeq;
   gf3be_bits mhalf;
   gf3be_bits mone;
   gf3be_bits got;

   halfv.f := 0.5;
   onep5.f := 1.5;
   two.f := 2.0;
   threeq.f := 0.75;
   mhalf.f := -0.5;
   mone.f := -1.0;

   got.f := onep5.f * halfv.f;
   expect3(got, threeq, 1);

   got.f := mhalf.f * two.f;
   expect3(got, mone, 4);

   pass();
}
