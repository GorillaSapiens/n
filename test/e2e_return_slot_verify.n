// n65cc -I .
// expectexit: 0
include "machine_6502.n"
struct Pair { int foo; int bar; };
void pass(void) { asm lda #$ff; asm ldx #0; asm ldy #0; asm jsr $ffff; }
Pair make_pair(int left, int right) { $$.foo := left; $$.bar := right; return; }
int bump_and_check(int x) { $$ := x; $$ += 1; if ($$ != 42) { return 99; } return; }
void main(void) {
   Pair p; p := make_pair(5, 6);
   if (p.foo != 5) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   if (p.bar != 6) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
   if (bump_and_check(41) != 42) { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }
   pass();
}
