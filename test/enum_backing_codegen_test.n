// n65cc -I .
// expectasmordered: _slot:
// expectasmordered: 	.res 1
// expectasmordered: _small:
// expectasmordered: 	.byte $03
// expectasmordered: _wide:
// expectasmordered: 	.byte $00, $01

include "machine_6502.n"

type u1 { $size:1 $unsigned };
type u2 { $size:2 $unsigned $endian:little };

enum Small { RED := 1, GREEN, BLUE };
enum Wide { BIG := 255, HUGE };

Small slot;
Small small := BLUE;
Wide wide := HUGE;
