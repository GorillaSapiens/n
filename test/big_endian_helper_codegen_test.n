// n65cc -I .
// expectasm: jsr _mulNbe
// expectasm: jsr _divNbe
// expectasm: jsr _lslNbe
// expectasm: jsr _lsrNbe
// expectasm: jsr _asrNbe
// expectasm: jsr _leNsbe

type void      { $size:0 };
type bool      { $size:1 };
type u2be      { $size:2 $unsigned $endian:big };
type s2be      { $size:2 $signed $endian:big };
type *         { $size:2 $unsigned $endian:little };

u2be mulbe(u2be a, u2be b) {
   return a * b;
}

u2be divbe(u2be a, u2be b) {
   return a / b;
}

u2be shlbe(u2be a, u2be b) {
   return a << b;
}

u2be shrbe(u2be a, u2be b) {
   return a >> b;
}

s2be sarbe(s2be a, u2be b) {
   return a >> b;
}

bool cmplebe(s2be a, s2be b) {
   return a <= b;
}
