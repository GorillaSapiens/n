// n65cc
// expectasm: .export __init_
// expectasm: .proc __init_
// expectasm: jsr _twice
// expectasmordered: jsr _twice
// expectasmordered: lda #<($0600 + 0)
// expectasmordered: sta ptr0
// expectasmordered: lda #>($0600 + 0)
// expectasmordered: sta ptr0+1
// expectasmordered: sta (ptr0),y
// expectasmordered: lda #$34
// expectasmordered: lda #$12
// expectasmordered: lda #<($0608 + 0)
// expectasmordered: sta ptr0
// expectasmordered: lda #>($0608 + 0)
// expectasmordered: sta ptr0+1
// expectasmordered: sta (ptr0),y

include "machine_6502.n"

type u8 { $size:1 $unsigned };

type intlit { $size:2 $signed $endian:little };

int twice(int x) {
   return x + x;
}

ref int direct@0x0600 := twice(3) + 1;
ref u8 split[2]@[none/0x0608] := { 52, 18 };

int main(void) {
   return 0;
}
