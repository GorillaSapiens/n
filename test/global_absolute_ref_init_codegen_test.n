// n65cc
// expectasm: .export __init_
// expectasm: .proc __init_
// expectasm: jsr twice
// expectasmordered: jsr twice
// expectasmordered: sta  $0600
// expectasmordered: sta  $0600 + 1
// expectasmordered: lda #$34
// expectasmordered: lda #$12
// expectasmordered: sta  $0608
// expectasmordered: sta  $0608 + 1

include "machine_6502.n"

type u8 { $size:1 $integer:unsigned };

type intlit { $size:2 $integer:signed $endian:little };

int twice(int x) {
   return x + x;
}

ref int direct@0x0600 := twice(3) + 1;
ref u8 split[2]@[none/0x0608] := { 52, 18 };

int main(void) {
   return 0;
}
