// n65cc -I .
// expectasm: jsr _add24
// expectasm: jsr _sub24
// expectasm: jsr _addN
// expectasm: jsr _subN
// expectasm: .import _add24
// expectasm: .import _sub24
// expectasm: .import _addN
// expectasm: .import _subN

type void      { $size:0 };
type bool      { $size:1 };
type s3        { $size:3 $signed $endian:little };
type s5        { $size:5 $signed $endian:little };
type *         { $size:2 $unsigned $endian:little };

s3 add3(s3 a, s3 b) {
   return a + b;
}

s3 sub3(s3 a, s3 b) {
   return a - b;
}

s5 add5(s5 a, s5 b) {
   return a + b;
}

s5 sub5(s5 a, s5 b) {
   return a - b;
}

s3 add3_wide(s3 a, s3 b) {
   return (a + b) + a;
}

s5 sub5_wide(s5 a, s5 b) {
   return (a - b) - a;
}
