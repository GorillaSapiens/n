// n65cc -I .
// expectasm: jsr operatorx2B__s3_p0_a0__s3_p0_a0
// expectasm: jsr operatorx2D__s3_p0_a0__s3_p0_a0
// expectasm: jsr operatorx2B__s5_p0_a0__s5_p0_a0
// expectasm: jsr operatorx2D__s5_p0_a0__s5_p0_a0
// expectasm: jsr _add24
// expectasm: jsr _subN
// expectasm: .import operatorx2B__s3_p0_a0__s3_p0_a0
// expectasm: .import operatorx2D__s3_p0_a0__s3_p0_a0
// expectasm: .import operatorx2B__s5_p0_a0__s5_p0_a0
// expectasm: .import operatorx2D__s5_p0_a0__s5_p0_a0
// expectasm: .import _add24
// expectasm: .import _subN

type void      { $size:0 };
type bool      { $size:1 };
type s3        { $size:3 $signed $endian:little };
type s5        { $size:5 $signed $endian:little };
type *         { $size:2 $unsigned $endian:little };

s3 add3(s3 a, s3 b) {
   return a + b;
}

s3 sub3(s3 a, s3 b) {
   return a - b;
}

s5 add5(s5 a, s5 b) {
   return a + b;
}

s5 sub5(s5 a, s5 b) {
   return a - b;
}

void add_assign3(ref s3 a, s3 b) {
   a += b;
}

void sub_assign5(ref s5 a, s5 b) {
   a -= b;
}
