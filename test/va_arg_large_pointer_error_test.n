// n65cc -I . -I ../libraries/nlib
// expectfail
// expecterr: pointer type '*' is too large for va_arg
type bool { $size:1 $integer:unsigned };
type void { $size:0 };
type char { $size:1 $integer:signed };
type * { $size:17 $integer:unsigned $endian:little };
type int { $size:2 $integer:signed $endian:little };
include "stdarg.n"
int scan(int tag, ...) {
   va_list ap;
   int x;
   va_arg(ap, x);
   return x + tag;
}
