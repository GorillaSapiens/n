// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type u2be { $size:2 $integer:unsigned $endian:big };
type s2be { $size:2 $integer:signed $endian:big };

u2be add_be(u2be a, u2be b) {
   return a + b;
}

u2be mul_be(u2be a, u2be b) {
   return a * b;
}

u2be mul_assign_be(u2be a, u2be b) {
   a *= b;
   return a;
}

u2be div_be(u2be a, u2be b) {
   return a / b;
}

u2be rem_be(u2be a, u2be b) {
   return a % b;
}

u2be shl_be(u2be a, u2be b) {
   return a << b;
}

u2be shr_be(u2be a, u2be b) {
   return a >> b;
}

s2be sar_be(s2be a, u2be b) {
   return a >> b;
}

u2be shl_assign_be(u2be a, u2be b) {
   a <<= b;
   return a;
}

u2be shr_assign_be(u2be a, u2be b) {
   a >>= b;
   return a;
}

s2be sar_assign_be(s2be a, u2be b) {
   a >>= b;
   return a;
}

u2be neg_bits_be(s2be a) {
   return (u2be)(-a);
}

bool lt_be(s2be a, s2be b) {
   return a < b;
}

void main(void) {
   if (add_be(0x0102`u2be, 0x0304`u2be) != 0x0406`u2be) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   if (mul_be(0x0012`u2be, 0x0003`u2be) != 0x0036`u2be) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
   if (mul_assign_be(0x0012`u2be, 0x0003`u2be) != 0x0036`u2be) { asm lda #$ff; asm ldx #8; asm ldy #0; asm jsr $ffff; }
   if (div_be(0x1234`u2be, 0x0011`u2be) != 0x0112`u2be) { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }
   if (rem_be(0x1234`u2be, 0x0011`u2be) != 0x0002`u2be) { asm lda #$ff; asm ldx #9; asm ldy #0; asm jsr $ffff; }
   if (shl_be(0x0102`u2be, 0x0008`u2be) != 0x0200`u2be) { asm lda #$ff; asm ldx #4; asm ldy #0; asm jsr $ffff; }
   if (shr_be(0x1200`u2be, 0x0008`u2be) != 0x0012`u2be) { asm lda #$ff; asm ldx #5; asm ldy #0; asm jsr $ffff; }
   if (sar_be(-256`s2be, 0x0008`u2be) != -1`s2be) { asm lda #$ff; asm ldx #6; asm ldy #0; asm jsr $ffff; }
   if (shl_assign_be(0x0102`u2be, 0x0008`u2be) != 0x0200`u2be) { asm lda #$ff; asm ldx #10; asm ldy #0; asm jsr $ffff; }
   if (shr_assign_be(0x1200`u2be, 0x0008`u2be) != 0x0012`u2be) { asm lda #$ff; asm ldx #11; asm ldy #0; asm jsr $ffff; }
   if (sar_assign_be(-256`s2be, 0x0008`u2be) != -1`s2be) { asm lda #$ff; asm ldx #12; asm ldy #0; asm jsr $ffff; }
   if (neg_bits_be(1`s2be) != 0xffff`u2be) { asm lda #$ff; asm ldx #13; asm ldy #0; asm jsr $ffff; }
   if (!lt_be(-2`s2be, 1`s2be)) { asm lda #$ff; asm ldx #7; asm ldy #0; asm jsr $ffff; }
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
