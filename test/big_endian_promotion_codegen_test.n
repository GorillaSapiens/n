// n65cc
// expectasm: .import _copysxNbe
// expectasm: .import _copyzxNbe
// expectasmordered: lda #$02
// expectasmordered: sta arg0
// expectasmordered: lda #$04
// expectasmordered: sta arg1
// expectasmordered: jsr _copysxNbe
// expectasmordered: lda #$04
// expectasmordered: sta arg0
// expectasmordered: lda #$05
// expectasmordered: sta arg1
// expectasmordered: jsr _copyzxNbe
// expectasm: jsr _ltNsbe
// forbidasm: and #$80

type void      { $size:0 };
type bool      { $size:1 $integer:unsigned };
type s2be      { $size:2 $integer:signed $endian:big };
type s4be      { $size:4 $integer:signed $endian:big };
type s5be      { $size:5 $integer:signed $endian:big };
type u4be      { $size:4 $integer:unsigned $endian:big };
type u5be      { $size:5 $integer:unsigned $endian:big };
type *         { $size:2 $integer:unsigned $endian:little };

s4be addmix(s2be a, s4be b) {
   return a + b;
}

u5be addu(u4be a, u5be b) {
   return a + b;
}

bool cmpmix(s2be a, s5be b) {
   return a < b;
}
