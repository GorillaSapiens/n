// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type u2be { $size:2 $integer:unsigned $endian:big };
type u2le { $size:2 $integer:unsigned $endian:little };
type f4be { $size:4 $float:ieee754 $endian:big };
type f4le { $size:4 $float:ieee754 $endian:little };

u2le addle(u2be a, u2le b) {
   return ($little)a + b;
}

u2be addbe(u2be a, u2le b) {
   return a + ($big)b;
}

void main(void) {
   u2be raw := 0x0002`u2be;
   u2le idx;
   u2le a[4];
   u2le *p;
   f4be fb;
   f4le fl;

   idx := ($little)raw;
   if (idx != 2`u2le) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }

   if (addle(0x0001`u2be, 2`u2le) != 3`u2le) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
   if (addbe(0x0001`u2be, 2`u2le) != 3`u2be) { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }

   a[0] := 11`u2le;
   a[1] := 22`u2le;
   a[2] := 33`u2le;
   a[3] := 44`u2le;
   if (a[($little)raw] != 33`u2le) { asm lda #$ff; asm ldx #4; asm ldy #0; asm jsr $ffff; }
   p := &a[0];
   p += ($little)raw;
   if (p[0] != 33`u2le) { asm lda #$ff; asm ldx #5; asm ldy #0; asm jsr $ffff; }

   fb := 1.5`f4be;
   fl := ($little)fb;
   if (!(fl == 1.5`f4le)) { asm lda #$ff; asm ldx #6; asm ldy #0; asm jsr $ffff; }

   fb := ($big)fl;
   if (!(fb == 1.5`f4be)) { asm lda #$ff; asm ldx #7; asm ldy #0; asm jsr $ffff; }

   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
