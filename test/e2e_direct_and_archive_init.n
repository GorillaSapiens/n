// n65cc -I .
// expectsim: OK
// archive: e2e_direct_and_archive_init__libthing.n
include "machine_6502.n"

int lib_value(void);

static char ok[4] := { 'O', 'K', '\n', 0 };
static char bad[5] := { 'B', 'A', 'D', '\n', 0 };

void print_ok(void) {
   asm lda #0;
   asm ldx #<_ok;
   asm ldy #>_ok;
   asm jsr $ffff;
}

void print_bad(void) {
   asm lda #0;
   asm ldx #<_bad;
   asm ldy #>_bad;
   asm jsr $ffff;
}

int twice(int x) {
   return x + x;
}

int seed := 2;
int direct_g := twice(seed) + 1;

void main(void) {
   if (direct_g == 5) {
      if (lib_value() == 9) {
         print_ok();
      }
      else {
         print_bad();
      }
   }
   else {
      print_bad();
   }
   while (1) {
   }
}
