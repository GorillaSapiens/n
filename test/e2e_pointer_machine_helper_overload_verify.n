// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type u1x { $size:1 $unsigned $endian:little };
type u2x { $size:2 $unsigned $endian:little };

int helper(char *dst, u1x value) {
   dst[0] := 'u';
   dst[1] := '0' + value;
   return 2;
}

int helper(char *dst, u2x value) {
   dst[0] := 'v';
   dst[1] := '0' + (value & 15`u2x);
   return 2;
}


void main(void) {
   char buf[8];
   char *p := buf;
   int used;

   used := helper(buf, 3`u1x);
   if (used != 2) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   used := helper(buf + 2, 258`u2x);
   if (used != 2) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
   used := helper(p + 4, 5`u1x);
   if (used != 2) { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }

   if (buf[0] != 'u') { asm lda #$ff; asm ldx #4; asm ldy #0; asm jsr $ffff; }
   if (buf[1] != '3') { asm lda #$ff; asm ldx #5; asm ldy #0; asm jsr $ffff; }
   if (buf[2] != 'v') { asm lda #$ff; asm ldx #6; asm ldy #0; asm jsr $ffff; }
   if (buf[3] != '2') { asm lda #$ff; asm ldx #7; asm ldy #0; asm jsr $ffff; }
   if (buf[4] != 'u') { asm lda #$ff; asm ldx #8; asm ldy #0; asm jsr $ffff; }
   if (buf[5] != '5') { asm lda #$ff; asm ldx #9; asm ldy #0; asm jsr $ffff; }

   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
