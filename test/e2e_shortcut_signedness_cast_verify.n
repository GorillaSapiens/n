// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type s1x { $size:1 $integer:signed $endian:little };
type u1x { $size:1 $integer:unsigned $endian:little };
type s2x { $size:2 $integer:signed $endian:little };
type u2x { $size:2 $integer:unsigned $endian:little };

u1x as_unsigned_byte(s1x x) {
   return ($unsigned)x;
}

s1x as_signed_byte(u1x x) {
   return ($signed)x;
}

u2x as_unsigned_word(s2x x) {
   return ($unsigned)x;
}

void main(void) {
   if (as_unsigned_byte(-1`s1x) != 255`u1x) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   if (as_signed_byte(255`u1x) != -1`s1x) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
   if (as_unsigned_word(-1`s2x) != 65535`u2x) { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
