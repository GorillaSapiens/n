// n65cc -I .
// expectasm: .zpexport capture$x
// expectasmordered: .segment "ZEROPAGE"
// expectasmordered: capture$x:
// expectasmordered: 	.res 2
// expectasmordered: .proc main
// expectasmordered: lda #$04
// expectasmordered: jsr _pushN
// expectasmordered: ldy #2
// expectasmordered: lda #$34
// expectasmordered: sta (fp),y
// expectasmordered: ldy #3
// expectasmordered: lda #$12
// expectasmordered: sta (fp),y
// expectasmordered: ldy #2
// expectasmordered: lda (fp),y
// expectasmordered: ldy #0
// expectasmordered: sta capture$x,y
// expectasmordered: ldy #3
// expectasmordered: lda (fp),y
// expectasmordered: ldy #1
// expectasmordered: sta capture$x,y
// forbidasm: .export capture$x
include "machine_6502.n"
mem register { $start:0x0000 $size:0x0010 $rw };

int capture(register int x) {
   return x;
}

int main(void) {
   return capture(0x1234);
}
