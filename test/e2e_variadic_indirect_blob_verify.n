// n65cc -I .
// expectexit: 0

include "machine_6502.n"

int sniff(int tag, ...) {
   char *p := __va_args;

   if (tag != 0x1020) { return 1; }
   if (__va_arg_bytes != 3) { return 2; }
   if (p[0] != 0x55) { return 3; }
   if (p[1] != 0x44) { return 4; }
   if (p[2] != 0x33) { return 5; }
   return 0;
}

int (*fp)(int tag, ...) := sniff;

void main(void) {
   if (fp(0x1020, 0x4455, 0x33) != 0) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
