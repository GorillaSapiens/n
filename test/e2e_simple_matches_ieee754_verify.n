// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type half_simple   { $size:2 $endian:little $float:simple };
type float_simple  { $size:4 $endian:little $float:simple };
type double_simple { $size:8 $endian:little $float:simple };

union half_bits {
   half h;
   half_simple hs;
   char b_ieee[2];
   char b_simple[2];
};

union float_bits {
   float f;
   float_simple fs;
   char b_ieee[4];
   char b_simple[4];
};

union double_bits {
   double d;
   double_simple ds;
   char b_ieee[8];
   char b_simple[8];
};

void fail1(void) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
void fail2(void) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
void fail3(void) { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

int same2(char a[2], char b[2]) {
   return a[0] == b[0] && a[1] == b[1];
}

int same4(char a[4], char b[4]) {
   return a[0] == b[0] && a[1] == b[1] && a[2] == b[2] && a[3] == b[3];
}

int same8(char a[8], char b[8]) {
   return a[0] == b[0] && a[1] == b[1] && a[2] == b[2] && a[3] == b[3]
      && a[4] == b[4] && a[5] == b[5] && a[6] == b[6] && a[7] == b[7];
}

void main(void) {
   half_bits hb;
   float_bits fb;
   double_bits db;

   hb.h := 1.5;
   hb.hs := 1.5;
   fb.f := 1.5;
   fb.fs := 1.5;
   db.d := 1.5;
   db.ds := 1.5;

   if (!same2(hb.b_ieee, hb.b_simple)) { fail1(); }
   if (!same4(fb.b_ieee, fb.b_simple)) { fail2(); }
   if (!same8(db.b_ieee, db.b_simple)) { fail3(); }

   pass();
}
