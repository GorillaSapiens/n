// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type f3le { $size:3 $float:SE8M15 $endian:little };
type f3be { $size:3 $float:SE8M15 $endian:big };

union f3le_bits {
   f3le f;
   char b[3];
};

union f3be_bits {
   f3be f;
   char b[3];
};

void fail1(void) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
void fail2(void) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
void fail3(void) { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }
void fail4(void) { asm lda #$ff; asm ldx #4; asm ldy #0; asm jsr $ffff; }
void fail5(void) { asm lda #$ff; asm ldx #5; asm ldy #0; asm jsr $ffff; }
void fail6(void) { asm lda #$ff; asm ldx #6; asm ldy #0; asm jsr $ffff; }

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   f3le_bits le;
   f3be_bits be;

   le.f := 1.5;
   be.f := 1.5;

   if (le.b[0] != 0) { fail1(); }
   if (le.b[1] != 192) { fail2(); }
   if (le.b[2] != 63) { fail3(); }

   if (be.b[0] != 63) { fail4(); }
   if (be.b[1] != 192) { fail5(); }
   if (be.b[2] != 0) { fail6(); }

   pass();
}
