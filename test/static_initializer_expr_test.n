// n65cc
// expectasm: _sum:
// expectasm: 	.byte $14, $00, $00
// expectasm: _less:
// expectasm: 	.byte $01
// expectasm: _four:
// expectasm: 	.byte $00, $00, $80, $40
// expectasm: _pair:
// expectasm: 	.byte $03, $00, $00, $04, $00, $00
// expectasm: _ptr:
// expectasm: 	.byte <(_base+1), >(_base+1)

type bool     { $size:1 };
type void     { $size:0 };
type *        { $size:2 $unsigned $endian:little };
type uint24_t { $size:3 $unsigned $endian:little };
type float_t  { $size:4 $float:ieee754 $endian:little }; // IEEE 754 binary32

uint24_t sum := (2 + 3) * 4;
bool less := 2 + 1 < 5;
float_t four := 1.5 + 2.5;
uint24_t pair[2] := { 1 + 2, 8 >> 1 };
uint24_t base;
uint24_t *ptr := &base + 1;

void main(void) {
}
