// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type u1 { $size:1 $integer:unsigned };
type u2 { $size:2 $integer:unsigned $endian:little };

enum Small { RED := 1, GREEN, BLUE };
enum Wide { BIG := 255, HUGE };

struct Pair {
   Small a;
   Wide b;
};

Small gsmall := BLUE;
Wide gwide := HUGE;

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   Small s := GREEN;
   Wide w := HUGE;

   if (gsmall != BLUE) {
      asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff;
   }

   if (gwide != HUGE) {
      asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff;
   }

   if (s != 2) {
      asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff;
   }

   if (w != 256) {
      asm lda #$ff; asm ldx #4; asm ldy #0; asm jsr $ffff;
   }

   if (sizeof(Pair) != 3) {
      asm lda #$ff; asm ldx #5; asm ldy #0; asm jsr $ffff;
   }

   switch (s) {
      case GREEN:
         break;
      default:
         asm lda #$ff; asm ldx #6; asm ldy #0; asm jsr $ffff;
   }

   switch (w) {
      case HUGE:
         break;
      default:
         asm lda #$ff; asm ldx #7; asm ldy #0; asm jsr $ffff;
   }

   pass();
}
