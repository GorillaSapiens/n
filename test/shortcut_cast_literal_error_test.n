// n65cc
// expectfail
// expecterr: shortcut cast '$unsigned' is only legal on already-typed ordinary fixed-width integer expressions

type void { $size:0 };
type bool { $size:1 };
type *    { $size:2 $unsigned $endian:little };
type u2   { $size:2 $unsigned $endian:little };

u2 bad(void) {
   return ($unsigned)1;
}
