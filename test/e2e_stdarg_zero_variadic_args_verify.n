// n65cc -I . -I ../libraries/nlib
// expectexit: 0

include "machine_6502.n"
include "stdarg.n"

int sniff(int tag, ...) {
   va_list ap;

   va_start(ap);
   if (tag != 0x2468) { return 1; }
   if (ap.bytes != 0) { return 2; }
   if (ap.offset != 0) { return 3; }
   va_end(ap);
   if (ap.bytes != 0) { return 4; }
   if (ap.offset != 0) { return 5; }
   return 0;
}

void main(void) {
   if (sniff(0x2468) != 0) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
