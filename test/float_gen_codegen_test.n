// n65cc -I .
// expectasm: .import nlf_gf32_add_impl
// expectasm: .import nlf_gf32_cmp_impl
// expectasm: .import nlf_gf64_add_impl
// expectasm: .import nlf_gf64_cmp_impl
// expectasm: .import nlf_gf32_mul_impl
// expectasm: .import nlf_gf32_div_impl
// expectasm: .import nlf_gf64_mul_impl
// expectasm: .import nlf_gf64_div_impl
// expectasm: .import nlf_gf3le_mul_impl
// expectasm: .import nlf_gf3le_div_impl
// expectasm: .import nlf_gf3be_mul_impl
// expectasm: .import nlf_gf3be_div_impl
// expectasm: .import nlf_gf3le_add_impl
// expectasm: .import nlf_gf3be_add_impl
// expectasm: jsr nlf_gf32_add_impl
// expectasm: jsr nlf_gf64_add_impl
// expectasm: jsr nlf_gf32_mul_impl
// expectasm: jsr nlf_gf32_div_impl
// expectasm: jsr nlf_gf64_mul_impl
// expectasm: jsr nlf_gf64_div_impl
// expectasm: jsr nlf_gf3le_mul_impl
// expectasm: jsr nlf_gf3le_div_impl
// expectasm: jsr nlf_gf3be_mul_impl
// expectasm: jsr nlf_gf3be_div_impl
// expectasm: jsr nlf_gf3le_add_impl
// expectasm: jsr nlf_gf3be_add_impl
// expectasm: jsr nlf_gf32_cmp_impl
// expectasm: jsr nlf_gf64_cmp_impl

include "machine_6502.n"

type gf32  { $size:4 $endian:little $float:ieee754 };
type gf64  { $size:8 $endian:little $float:ieee754 };
type gf3le { $size:3 $endian:little $float:simple };
type gf3be { $size:3 $endian:big    $float:simple };

include "generated_gf32_ops.n"
include "generated_gf64_ops.n"
include "generated_gf3le_ops.n"
include "generated_gf3be_ops.n"

void main(void) {
   gf32 a32;
   gf32 b32;
   gf32 c32;
   gf64 a64;
   gf64 b64;
   gf64 c64;
   gf3le a3le;
   gf3le b3le;
   gf3le c3le;
   gf3be a3be;
   gf3be b3be;
   gf3be c3be;
   bool q;

   a32 := 1.0;
   b32 := 0.5;
   c32 := a32 + b32;
   c32 := a32 - b32;
   c32 := a32 * b32;
   c32 := a32 / b32;
   q := a32 > b32;

   a64 := 2.0;
   b64 := 0.5;
   c64 := a64 + b64;
   c64 := a64 - b64;
   c64 := a64 * b64;
   c64 := a64 / b64;
   q := a64 <= b64;

   a3le := 1.0;
   b3le := 0.5;
   c3le := a3le + b3le;
   c3le := a3le - b3le;
   c3le := a3le * b3le;
   c3le := a3le / b3le;
   q := a3le != b3le;

   a3be := 1.0;
   b3be := 0.5;
   c3be := a3be + b3be;
   c3be := a3be - b3be;
   c3be := a3be * b3be;
   c3be := a3be / b3be;
   q := a3be >= b3be;

   if (q) {
      asm nop;
   }
}
