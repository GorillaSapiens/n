// n65cc

type void      { $size:0 };
type bool     { $size:1 $integer:unsigned };
type char      { $size:1    $integer:signed };
type uchar     { $size:1  $integer:unsigned };
type *         { $size:2  $integer:unsigned $endian:little };
type int       { $size:3    $integer:signed $endian:little };
type uint      { $size:3  $integer:unsigned $endian:little };

int main(void) {
   int a[4];
   int *p := &a[0];
   int *q := &a[3];
   p := p + 2;
   q--;
   return q - p;
}
