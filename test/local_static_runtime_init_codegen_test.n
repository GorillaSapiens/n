// n65cc
// expectasm: .export __init_
// expectasm: .proc __init_
// expectasm: _demo$s:
// expectasm: .res 2
// expectasm: jsr _twice
// expectasm: sta _demo$s,y

type void { $size:0 };
type bool { $size:1 };
type *    { $size:2 $unsigned $endian:little };
type int  { $size:2 $signed $endian:little };

int twice(int x) {
   return x + x;
}

int demo(void) {
   static int s := twice(3) + 1;
   return s;
}
