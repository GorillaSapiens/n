// linkcfg: named.cfg
// expectmap: DATA.banana
// expectmap: BSS.banana
// expectsim: OK
include "machine_6502.n"
mem banana { $start:0x0400 $size:0x0100 $rw };

banana int x := 5;
banana char z;

static char ok[4] := { 'O', 'K', '\n', 0 };
static char bad[5] := { 'B', 'A', 'D', '\n', 0 };

void print_ok(void) {
   asm lda #0;
   asm ldx #<_ok;
   asm ldy #>_ok;
   asm jsr $ffff;
}

void print_bad(void) {
   asm lda #0;
   asm ldx #<_bad;
   asm ldy #>_bad;
   asm jsr $ffff;
}

void main(void) {
   if (x == 5 && z == 0) {
      print_ok();
   }
   else {
      print_bad();
   }
   while (1) {
   }
}
