// expectsim: FP OK
include "machine_6502.n"

static char ok[7] := { 'F', 'P', ' ', 'O', 'K', '\n', 0 };
static char bad[8] := { 'F', 'P', ' ', 'B', 'A', 'D', '\n', 0 };

void print_ok(void) {
   asm lda #0;
   asm ldx #<_ok;
   asm ldy #>_ok;
   asm jsr $ffff;
}

void print_bad(void) {
   asm lda #0;
   asm ldx #<_bad;
   asm ldy #>_bad;
   asm jsr $ffff;
}

int inc(int x) {
   return x + 1;
}

int (*fp)(int) := inc;

void main(void) {
   if (fp(4) == 5) {
      print_ok();
   }
   else {
      print_bad();
   }
   while (1) {
   }
}
