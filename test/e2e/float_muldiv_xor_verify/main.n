// expectexit: 0
include "machine_6502.n"

union f32bits {
   float f;
   char b[4];
};

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   f32bits lhs;
   f32bits rhs;
   f32bits mul_expr;
   f32bits div_expr;
   f32bits mul_assign;
   f32bits div_assign;
   f32bits box[2];

   lhs.b[0] := 1;
   lhs.b[1] := 2;
   lhs.b[2] := 3;
   lhs.b[3] := 4;

   rhs.b[0] := 16;
   rhs.b[1] := 32;
   rhs.b[2] := 48;
   rhs.b[3] := 64;

   mul_expr.f := lhs.f * rhs.f;
   div_expr.f := lhs.f / rhs.f;

   mul_assign.f := lhs.f;
   mul_assign.f *= rhs.f;

   div_assign.f := lhs.f;
   div_assign.f /= rhs.f;

   box[0].f := lhs.f;
   box[1].f := rhs.f;
   box[0].f *= box[1].f;
   box[1].f /= lhs.f;

   if (mul_expr.b[0] != 17) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   if (mul_expr.b[1] != 34)  { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
   if (mul_expr.b[2] != 51)  { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }
   if (mul_expr.b[3] != 68)  { asm lda #$ff; asm ldx #4; asm ldy #0; asm jsr $ffff; }

   if (div_expr.b[0] != 17) { asm lda #$ff; asm ldx #5; asm ldy #0; asm jsr $ffff; }
   if (div_expr.b[1] != 34)  { asm lda #$ff; asm ldx #6; asm ldy #0; asm jsr $ffff; }
   if (div_expr.b[2] != 51)  { asm lda #$ff; asm ldx #7; asm ldy #0; asm jsr $ffff; }
   if (div_expr.b[3] != 68)  { asm lda #$ff; asm ldx #8; asm ldy #0; asm jsr $ffff; }

   if (mul_assign.b[0] != 17) { asm lda #$ff; asm ldx #9;  asm ldy #0; asm jsr $ffff; }
   if (mul_assign.b[1] != 34)  { asm lda #$ff; asm ldx #10; asm ldy #0; asm jsr $ffff; }
   if (mul_assign.b[2] != 51)  { asm lda #$ff; asm ldx #11; asm ldy #0; asm jsr $ffff; }
   if (mul_assign.b[3] != 68)  { asm lda #$ff; asm ldx #12; asm ldy #0; asm jsr $ffff; }

   if (div_assign.b[0] != 17) { asm lda #$ff; asm ldx #13; asm ldy #0; asm jsr $ffff; }
   if (div_assign.b[1] != 34)  { asm lda #$ff; asm ldx #14; asm ldy #0; asm jsr $ffff; }
   if (div_assign.b[2] != 51)  { asm lda #$ff; asm ldx #15; asm ldy #0; asm jsr $ffff; }
   if (div_assign.b[3] != 68)  { asm lda #$ff; asm ldx #16; asm ldy #0; asm jsr $ffff; }

   if (box[0].b[0] != 17) { asm lda #$ff; asm ldx #17; asm ldy #0; asm jsr $ffff; }
   if (box[0].b[1] != 34)  { asm lda #$ff; asm ldx #18; asm ldy #0; asm jsr $ffff; }
   if (box[0].b[2] != 51)  { asm lda #$ff; asm ldx #19; asm ldy #0; asm jsr $ffff; }
   if (box[0].b[3] != 68)  { asm lda #$ff; asm ldx #20; asm ldy #0; asm jsr $ffff; }

   if (box[1].b[0] != 17) { asm lda #$ff; asm ldx #21; asm ldy #0; asm jsr $ffff; }
   if (box[1].b[1] != 34)  { asm lda #$ff; asm ldx #22; asm ldy #0; asm jsr $ffff; }
   if (box[1].b[2] != 51)  { asm lda #$ff; asm ldx #23; asm ldy #0; asm jsr $ffff; }
   if (box[1].b[3] != 68)  { asm lda #$ff; asm ldx #24; asm ldy #0; asm jsr $ffff; }

   pass();
}
