// n65cc -I .
// expectexit: 0

include "machine_6502.n"

type s4 { $size:4 $signed $endian:little };
type u4 { $size:4 $unsigned $endian:little };

int main(void) {
   s4 a := 10`s4;
   s4 b := 3`s4;
   u4 ua := 10`u4;
   u4 ub := 3`u4;

   if (a + b != 13`s4) { asm lda #$ff; asm ldx #1;  asm ldy #0; asm jsr $ffff; }
   if (a - b != 7`s4)  { asm lda #$ff; asm ldx #2;  asm ldy #0; asm jsr $ffff; }
   if (a * b != 30`s4) { asm lda #$ff; asm ldx #3;  asm ldy #0; asm jsr $ffff; }
   if (a / b != 3`s4)  { asm lda #$ff; asm ldx #4;  asm ldy #0; asm jsr $ffff; }
   if (a % b != 1`s4)  { asm lda #$ff; asm ldx #5;  asm ldy #0; asm jsr $ffff; }
   if ((a < b) != 0`bool)  { asm lda #$ff; asm ldx #6;  asm ldy #0; asm jsr $ffff; }
   if ((a >= b) != 1`bool) { asm lda #$ff; asm ldx #7;  asm ldy #0; asm jsr $ffff; }
   if ((ua << 1`u4) != 20`u4) { asm lda #$ff; asm ldx #8;  asm ldy #0; asm jsr $ffff; }
   if ((ua >> 1`u4) != 5`u4)  { asm lda #$ff; asm ldx #9;  asm ldy #0; asm jsr $ffff; }
   if ((ua & ub) != 2`u4)     { asm lda #$ff; asm ldx #10; asm ldy #0; asm jsr $ffff; }
   if ((ua | ub) != 11`u4)    { asm lda #$ff; asm ldx #11; asm ldy #0; asm jsr $ffff; }
   if ((ua ^ ub) != 9`u4)     { asm lda #$ff; asm ldx #12; asm ldy #0; asm jsr $ffff; }
   if ((~ub) != (~3`u4))      { asm lda #$ff; asm ldx #13; asm ldy #0; asm jsr $ffff; }
   if ((-b) != -3`s4)         { asm lda #$ff; asm ldx #14; asm ldy #0; asm jsr $ffff; }

   asm lda #$ff; asm ldx #0; asm ldy #0; asm jsr $ffff;
   return 0;
}
