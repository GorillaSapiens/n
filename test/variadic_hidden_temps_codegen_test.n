// n65cc -I .
// expectasm: .proc probe
// expectasmordered: lda #$06
// expectasmordered: jsr _fp2ptr1m
// expectasmordered: lda (ptr1),y
// expectasmordered: sta (fp),y
// expectasmordered: lda #$04
// expectasmordered: jsr _fp2ptr0m

include "machine_6502.n"

int probe(int tag, ...) {
   void *raw := __va_args;
   char *p := raw;
   return __va_arg_bytes + p[0];
}
