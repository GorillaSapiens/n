// n65cc -I .
// expectexit: 0
include "machine_6502.n"

int ord2(int a, int b) {
   return a + 10 * b;
}

int ord3(int a, int b, int c) {
   return a + 10 * b + 100 * c;
}

int ord4(int a, int b, int c, int d) {
   return a + 10 * b + 100 * c + 1000 * d;
}

void main(void) {
   int r2;
   int r3;
   int r4;

   r2 := ord2(1, 2);
   r3 := ord3(1, 2, 3);
   r4 := ord4(1, 2, 3, 4);

   if (r2 != 21) { asm lda #$ff; asm ldx #1; asm ldy #0; asm jsr $ffff; }
   if (r3 != 321) { asm lda #$ff; asm ldx #2; asm ldy #0; asm jsr $ffff; }
   if (r4 != 4321) { asm lda #$ff; asm ldx #3; asm ldy #0; asm jsr $ffff; }
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}
