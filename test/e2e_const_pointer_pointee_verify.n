// n65cc -I .
// expectexit: 0

include "machine_6502.n"


static int read_first(const char* p) {
   return p[0];
}

void pass(void) {
   asm lda #$ff;
   asm ldx #0;
   asm ldy #0;
   asm jsr $ffff;
}

void main(void) {
   char a[1], b[1];
   const char* p;

   a[0] := 1;
   b[0] := 2;

   p := a;
   p := b;

   if (read_first(p) != 2) {
      asm lda #$ff;
      asm ldx #1;
      asm ldy #0;
      asm jsr $ffff;
   }

   pass();
}
