// n65cc
// expectasm: and #$80
// expectasm: ldy #3
// expectasm: sta (fp),y
// expectasm: ldy #9
// expectasm: lda #$00
// expectasm: jsr operatorx3C__s5_p0_a0__s5_p0_a0

type void      { $size:0 };
type bool      { $size:1 };
type s2        { $size:2 $signed $endian:little };
type u4        { $size:4 $unsigned $endian:little };
type s4        { $size:4 $signed $endian:little };
type s5        { $size:5 $signed $endian:little };
type *         { $size:2 $unsigned $endian:little };

s4 addmix(s2 a, s4 b) {
   return a + b;
}

s5 mixsign(s2 a, u4 b) {
   return a + b;
}

bool cmpmix(s2 a, u4 b) {
   return a < b;
}
