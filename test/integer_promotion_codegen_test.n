// n65cc
// expectasm: .import _copysxNle
// expectasm: .import _copyzxNle
// expectasmordered: lda #$02
// expectasmordered: sta arg0
// expectasmordered: lda #$04
// expectasmordered: sta arg1
// expectasmordered: jsr _copysxNle
// expectasmordered: lda #$04
// expectasmordered: sta arg0
// expectasmordered: lda #$05
// expectasmordered: sta arg1
// expectasmordered: jsr _copyzxNle
// expectasm: jsr _ltNsle
// forbidasm: and #$80

type void      { $size:0 };
type bool      { $size:1 $integer:unsigned };
type s2        { $size:2 $integer:signed $endian:little };
type s4        { $size:4 $integer:signed $endian:little };
type s5        { $size:5 $integer:signed $endian:little };
type u4        { $size:4 $integer:unsigned $endian:little };
type u5        { $size:5 $integer:unsigned $endian:little };
type *         { $size:2 $integer:unsigned $endian:little };

s4 addmix(s2 a, s4 b) {
   return a + b;
}

u5 addu(u4 a, u5 b) {
   return a + b;
}

bool cmpmix(s2 a, s5 b) {
   return a < b;
}
