// n65cc
// expectasm: .import _copysxN
// expectasm: .import _copyzxN
// expectasmordered: lda #$02
// expectasmordered: sta arg0
// expectasmordered: lda #$04
// expectasmordered: sta arg1
// expectasmordered: jsr _copysxN
// expectasmordered: lda #$04
// expectasmordered: sta arg0
// expectasmordered: lda #$05
// expectasmordered: sta arg1
// expectasmordered: jsr _copyzxN
// expectasm: jsr _ltNs
// forbidasm: and #$80

type void      { $size:0 };
type bool      { $size:1 };
type s2        { $size:2 $signed $endian:little };
type s4        { $size:4 $signed $endian:little };
type s5        { $size:5 $signed $endian:little };
type u4        { $size:4 $unsigned $endian:little };
type u5        { $size:5 $unsigned $endian:little };
type *         { $size:2 $unsigned $endian:little };

s4 addmix(s2 a, s4 b) {
   return a + b;
}

u5 addu(u4 a, u5 b) {
   return a + b;
}

bool cmpmix(s2 a, s5 b) {
   return a < b;
}
