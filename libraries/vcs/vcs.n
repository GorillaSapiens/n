// Atari 2600 / VCS machine definition.
//
// This describes the common unbanked 6507-visible view of the machine:
// - 128 bytes of RIOT RAM in zero page ($80-$FF)
// - mirrored page-1 stack RAM at $180-$1FF
// - 4K cartridge ROM conventionally linked at $F000-$FFFF

type void     { $size:0 };
type char     { $size:1 };
type bool     { $size:1 };
type *        { $size:2 $endian:little };
type int      { $size:2 $endian:little };
type long     { $size:4 $endian:little };
type longlong { $size:8 $endian:little };
type half     { $size:2 $endian:little $float:SE5M10 };
type float    { $size:4 $endian:little $float:SE8M23 };
type double   { $size:8 $endian:little $float:SE11M52 };

mem ram      { $start:0x0080 $size:0x0080 $rw $priority:2 };
mem cpustack { $start:0x0180 $size:0x0080 $rw };
mem rom      { $start:0xF000 $size:0x1000 $ro $priority:1 };

xform {
   '\a' 0x07,
   '\b' 0x08,
   '\e' 0x1B,
   '\f' 0x0C,
   '\n' 0x0A,
   '\r' 0x0D,
   '\t' 0x09,
   '\v' 0x0B,
   '\\' 0x5C,
   '\'' 0x27,
   '\"' 0x22,
   '\?' 0x3F,
   '\0' 0x00,
};

include "tia.n"
include "riot.n"
